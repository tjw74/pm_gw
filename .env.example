SERVER_HOST=127.0.0.1
SERVER_PORT=8080
LOG_LEVEL=info

# HMAC secret for signed session tokens. Static DEV_USER{N}_TOKEN values also work in v1.
AUTH_SECRET=replace_me

POLY_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLY_CLOB_BASE_URL=https://clob.polymarket.com
POLY_DATA_API_BASE_URL=https://data-api.polymarket.com
POLY_CLOB_MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLY_CLOB_USER_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user
POLY_RTDS_WS_URL=wss://ws-live-data.polymarket.com

ENABLE_BINANCE_FEED=true
ENABLE_COINBASE_FEED=true
ENABLE_KRAKEN_FEED=true
ENABLE_OKX_FEED=true
ENABLE_BITSTAMP_FEED=true

BTC_MARKET_SEED_SLUG=bitcoin-up-or-down
MARKET_ROLLOVER_ENABLED=true
COMMAND_MAX_AGE_SECS=20

# Safety checks are optional and intentionally permissive by default.
ENABLE_KILL_SWITCH=false
OPTIONAL_MAX_ORDER_SIZE=
OPTIONAL_MAX_NOTIONAL=
OPTIONAL_COMMAND_RATE_LIMIT_PER_SEC=

DEV_USER1_TOKEN=replace_with_long_random_token_or_signed_token
DEV_USER1_PRIVATE_KEY=replace_me

DEV_USER2_TOKEN=replace_with_long_random_token_or_signed_token
DEV_USER2_PRIVATE_KEY=replace_me
