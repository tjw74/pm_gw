[Unit]
Description=Polymarket Gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=www-data
Group=www-data
EnvironmentFile=/etc/polymarket_gateway.env
WorkingDirectory=/opt/polymarket_gateway
ExecStart=/opt/polymarket_gateway/polymarket_gateway
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/tmp
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
