hzyshd.io {
    encode gzip zstd

    redir /trade /trade/ 308

    handle_path /trade* {
        reverse_proxy 127.0.0.1:4174
    }

    handle /ws {
        reverse_proxy 127.0.0.1:8080
    }

    handle /ws/* {
        reverse_proxy 127.0.0.1:8080
    }

    handle /api/* {
        reverse_proxy 127.0.0.1:8080
    }

    handle /healthz {
        reverse_proxy 127.0.0.1:8080
    }

    handle /readyz {
        reverse_proxy 127.0.0.1:8080
    }

    handle {
        reverse_proxy 127.0.0.1:4173
    }
}
